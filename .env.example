# canadaaccountants-backend — env var template
# Values live in Railway production; this file lists key NAMES with empty values.
# Never commit a real value to this file. The pre-commit hook + CI scan back this rule.

# ── Required runtime secrets ──────────────────────────────────────────────────
DATABASE_URL=
JWT_SECRET=
ADMIN_API_KEY=
RESEND_API_KEY=
RESEND_WEBHOOK_SIGNING_SECRET=
RESEND_WEBHOOK_SECRET=
ZEROBOUNCE_API_KEY=
ANTHROPIC_API_KEY=
SENTRY_DSN=

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ASSOCIATE=
STRIPE_PRICE_ASSOCIATE_YEARLY=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_PROFESSIONAL_YEARLY=
STRIPE_PRICE_ENTERPRISE=
STRIPE_PRICE_ENTERPRISE_YEARLY=

# ── Inbound mail (Gmail IMAP poller + Resend webhook) ─────────────────────────
GMAIL_IMAP_USER=
GMAIL_IMAP_APP_PASSWORD=
INBOUND_WEBHOOK_SECRET=
UNSUBSCRIBE_SECRET=

# ── Cross-platform referral (CBE) ─────────────────────────────────────────────
CBE_BACKEND_URL=
CBE_REFERRAL_API_KEY=
CBE_DATABASE_URL=
REFERRAL_SECRET=

# ── Sibling backend URLs (cross-platform calls) ───────────────────────────────
ACC_BACKEND_URL=
ACC_BASE=
ACC_DATABASE_URL=
LAW_BACKEND_URL=
INV_BACKEND_URL=

# ── Email + URL config ────────────────────────────────────────────────────────
FROM_EMAIL=
FRONTEND_URL=
BACKEND_URL=
BACKEND_PUBLIC_URL=
ADMIN_EMAIL=
CASL_PHYSICAL_ADDRESS=

# ── Operational flags / thresholds ────────────────────────────────────────────
FOUNDER_AUTO_SEND_PAUSED=
BREAKDOWN_AUTO_REPLY_ENABLED=
BREAKDOWN_DAILY_CAP=
V2_RUNNER_LAUNCH_READY=
WEBHOOK_EVENTS_TABLE=
WEBHOOK_EVENTS_TS_COL=
WEBHOOK_HEALTH_WARN_MIN=
WEBHOOK_HEALTH_FAIL_MIN=

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=
PORT=
PGSSL=
RAILWAY_PUBLIC_DOMAIN=
